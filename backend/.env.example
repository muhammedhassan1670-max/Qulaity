# QMS Enterprise 4.0 - Backend Environment Configuration

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/qms_enterprise?schema=public"

# Server
PORT=3001
NODE_ENV=development
API_VERSION=v1

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Redis (for caching and queues)
REDIS_URL=redis://localhost:6379

# MQTT Broker (for IoT)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@qms-enterprise.com

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
JSON_BODY_LIMIT=10mb

# CORS
# Comma-separated when more than one frontend origin is needed.
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
