# Frontend production environment for Vercel.
# Copy these values into Vercel Project Settings > Environment Variables.

# Frontend-only/offline pilot mode.
# Keep this true until an online API is deployed and connected.
VITE_USE_MOCK_API=true

# Set this to the deployed backend API later, for example:
# https://your-qms-api.example.com/api/v1
VITE_API_URL=

# Disable websocket in frontend-only deployment unless the backend websocket is online.
VITE_ENABLE_WEBSOCKET=false

# Default tenant code used by the local/offline auth fallback.
VITE_DEFAULT_TENANT_CODE=QMS

# Keep private keys out of VITE_* variables. VITE variables are public in the browser.
