NODE_ENV=production
PORT=3001

# Supabase runtime connection string.
# For a persistent Node backend, prefer the Session pooler on port 5432.
# For serverless hosting, use the Transaction pooler on port 6543 with pgbouncer=true.
DATABASE_URL=postgresql://postgres.zopeswdcvdrekuycsxcm:YOUR-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Used by Prisma migrations and seed.
DIRECT_URL=postgresql://postgres.zopeswdcvdrekuycsxcm:YOUR-PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Use a long random secret in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# First online admin created by npm run seed.
ADMIN_EMAIL=admin@qms.com
ADMIN_PASSWORD=replace-with-a-strong-production-password
ADMIN_NAME=System Administrator

# Frontend origin deployed on Vercel.
CORS_ORIGIN=https://qulaity.vercel.app

JSON_BODY_LIMIT=2mb
