NODE_ENV=production
PORT=3001

# Supabase Postgres connection string.
DATABASE_URL=postgresql://prisma.PROJECT_REF:PASSWORD@HOST:5432/postgres

# Use a long random secret in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d

# First online admin created by npm run seed.
ADMIN_EMAIL=admin@qms.com
ADMIN_PASSWORD=replace-with-a-strong-production-password
ADMIN_NAME=System Administrator

# Frontend origin deployed on Vercel.
CORS_ORIGIN=https://qulaity.vercel.app

JSON_BODY_LIMIT=2mb
