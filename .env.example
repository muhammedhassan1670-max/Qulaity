# QMS Enterprise 4.0 - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# API Configuration
# ============================================
# Backend API URL
VITE_API_URL=http://localhost:3001/api/v1

# Use mock API instead of real backend (true/false)
VITE_USE_MOCK_API=true

# ============================================
# Authentication
# ============================================
# JWT token expiry in minutes
VITE_TOKEN_EXPIRY=60

# Enable biometric authentication (if available)
VITE_ENABLE_BIOMETRIC=false

# ============================================
# Features
# ============================================
# Enable 3D visualization
VITE_ENABLE_3D=true

# Default 3D quality (high/medium/low)
VITE_3D_QUALITY=high

# Enable real-time updates via WebSocket
VITE_ENABLE_WEBSOCKET=true

# WebSocket server URL
VITE_WS_URL=ws://localhost:3001

# ============================================
# IoT Integration
# ============================================
# Enable IoT device integration
VITE_ENABLE_IOT=true

# IoT data refresh interval (seconds)
VITE_IOT_REFRESH_INTERVAL=5

# ============================================
# AI Features
# ============================================
# Enable AI predictions and analytics
VITE_ENABLE_AI=true

# AI model endpoint (if using external AI service)
VITE_AI_ENDPOINT=

# Never place private API keys in VITE_* variables; they are exposed to the browser.
# Call private AI providers from the backend instead.

# ============================================
# Analytics & Monitoring
# ============================================
# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Google Analytics ID (optional)
# VITE_GA_ID=your_ga_id

# Sentry DSN for error tracking (optional)
# VITE_SENTRY_DSN=your_sentry_dsn

# ============================================
# Internationalization
# ============================================
# Default language
VITE_DEFAULT_LANGUAGE=en

# Available languages (comma separated)
VITE_AVAILABLE_LANGUAGES=en,ar,es,fr

# ============================================
# File Upload
# ============================================
# Max file upload size (MB)
VITE_MAX_FILE_SIZE=50

# Allowed file types
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.mp4

# ============================================
# Development Settings
# ============================================
# Enable debug mode
VITE_DEBUG=false

# Enable React Query DevTools
VITE_ENABLE_DEVTOOLS=false
